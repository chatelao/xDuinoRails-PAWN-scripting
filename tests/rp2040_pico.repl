nvic: IRQControllers.NVIC @ sysbus 0xe000e000

cpu: CPU.CortexM @ sysbus
    cpuType: "cortex-m0+"
    nvic: nvic
    id: 0

nvic:
    -> cpu@0

sram: Memory.MappedMemory @ sysbus 0x20000000
    size: 0x42000

flash: Memory.MappedMemory @ sysbus 0x10000000
    size: 0x200000

uart0: UART.PL011 @ sysbus 0x40034000
    IRQ -> nvic@20

sysbus:
    init:
        Tag <0x40000000 0x1000> "SysInfo" 0xDEADBEEF
        Tag <0x40004000 0x1000> "SysCfg" 0xFFFFFFFF
        Tag <0x40008000 0x38> "Clocks_GPOUT" 0x0
        Tag <0x40008038 0x4> "Clocks_REF_SELECTED" 0x1
        Tag <0x4000803c 0x8> "Clocks_SYS_CTRL" 0x0
        Tag <0x40008044 0x4> "Clocks_SYS_SELECTED" 0x1
        Tag <0x40008048 0x50> "Clocks_REST" 0x0
        Tag <0x40008098 0x4> "Clocks_FC0_STATUS" 0x10
        Tag <0x4000809c 0xF64> "Clocks_END" 0x0
        Tag <0x4000c000 0x8> "Resets_REG" 0x0
        Tag <0x4000c008 0x4> "Resets_DONE" 0xFFFFFFFF
        Tag <0x4000c00c 0xFF4> "Resets_REST" 0x0
        Tag <0x40010000 0x1000> "BusCtrl" 0xFFFFFFFF
        Tag <0x40014000 0x1000> "IO_BANK0" 0xFFFFFFFF
        Tag <0x4001c000 0x1000> "PADS_BANK0" 0xFFFFFFFF
        Tag <0x40024000 0x4> "XOSC_CTRL" 0x0
        Tag <0x40024004 0x4> "XOSC_STATUS" 0x80000000
        Tag <0x40024008 0xFF8> "XOSC_REST" 0x0
        Tag <0x40028000 0x4> "PLL_SYS_CS" 0x80000000
        Tag <0x40028004 0xFFC> "PLL_SYS_REST" 0x0
        Tag <0x4002c000 0x4> "PLL_USB_CS" 0x80000000
        Tag <0x4002c004 0xFFC> "PLL_USB_REST" 0x0
        Tag <0x40054000 0x1000> "TIMER" 0xFFFFFFFF
        Tag <0x40060000 0x18> "ROSC_REG" 0x0
        Tag <0x40060018 0x4> "ROSC_STATUS" 0x80000000
        Tag <0x4006001c 0xFE4> "ROSC_REST" 0x0
        Tag <0x40064000 0x1000> "VREG" 0xFFFFFFFF
        Tag <0x40058000 0x1000> "WATCHDOG" 0xFFFFFFFF
        Tag <0xd0000000 0x4> "SIO_CPUID" 0x0
        Tag <0xd0000004 0xFC> "SIO_REST" 0x0
        Tag <0xd0000100 0x80> "SIO_SPINLOCKS" 0xFFFFFFFF
        Tag <0xd0000180 0xE80> "SIO_END" 0x0
