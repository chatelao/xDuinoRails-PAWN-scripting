nvic: IRQControllers.NVIC @ sysbus 0xe000e000

cpu: CPU.CortexM @ sysbus
    cpuType: "cortex-m0+"
    nvic: nvic
    id: 0

nvic:
    -> cpu@0

sram: Memory.MappedMemory @ sysbus 0x20000000
    size: 0x42000

flash: Memory.MappedMemory @ sysbus 0x10000000
    size: 0x200000

uart0: UART.PL011 @ sysbus 0x40034000
    IRQ -> nvic@20

sio: Memory.MappedMemory @ sysbus 0xd0000000
    size: 0x1000

sysbus:
    init:
        # Improved peripheral mocks for RP2040
        # Atomic aliases (SET, CLR, XOR) at +0x1000, +0x2000, +0x3000 mean size should be 0x4000
        Tag <0x40000000 0x4000> "SysInfo" 0xDEADBEEF
        Tag <0x40004000 0x4000> "SysCfg" 0x0
        Tag <0x40008000 0x4000> "Clocks" 0x0
        Tag <0x4000c000 0x4000> "Resets" 0x01FFFFFF  # RESET_DONE bits
        Tag <0x40010000 0x4000> "PSM" 0xFFFFFFFF
        Tag <0x40014000 0x4000> "IO_BANK0" 0xFFFFFFFF
        Tag <0x40018000 0x4000> "IO_QSPI" 0x0
        Tag <0x4001c000 0x4000> "PADS_BANK0" 0x0
        Tag <0x40020000 0x4000> "PADS_QSPI" 0x0
        Tag <0x40024000 0x4000> "XOSC" 0x80000000    # STABLE bit
        Tag <0x40028000 0x4000> "PLL_SYS" 0x80000000 # LOCK bit
        Tag <0x4002c000 0x4000> "PLL_USB" 0x80000000 # LOCK bit
        Tag <0x40030000 0x4000> "BusCtrl" 0xFFFFFFFF
        Tag <0x4003c000 0x4000> "SPI0" 0x0
        Tag <0x40040000 0x4000> "SPI1" 0x0
        Tag <0x40044000 0x4000> "I2C0" 0x0
        Tag <0x40048000 0x4000> "I2C1" 0x0
        Tag <0x4004c000 0x4000> "ADC" 0x0
        Tag <0x40050000 0x4000> "PWM" 0x0
        Tag <0x40054000 0x4000> "TIMER" 0x0
        Tag <0x40058000 0x4000> "WATCHDOG" 0x0
        Tag <0x40060000 0x4000> "ROSC" 0x80000000
        Tag <0x40064000 0x4000> "VREG" 0x00001000   # ROK bit
        Tag <0x50110000 0x10000> "USB" 0x0           # Mock USB controller
