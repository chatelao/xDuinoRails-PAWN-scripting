nvic: IRQControllers.NVIC @ sysbus 0xe000e000

cpu: CPU.CortexM @ sysbus
    cpuType: "cortex-m0+"
    nvic: nvic
    id: 0

nvic:
    -> cpu@0

sram: Memory.MappedMemory @ sysbus 0x20000000
    size: 0x42000

flash: Memory.MappedMemory @ sysbus 0x10000000
    size: 0x200000

uart0: UART.PL011 @ sysbus 0x40034000
    IRQ -> nvic@20

sio: Memory.MappedMemory @ sysbus 0xd0000000
    size: 0x1000

sysbus:
    init:
        Tag <0x40000000 0x4000> "SysInfo" 0xDEADBEEF
        Tag <0x40004000 0x4000> "SysCfg" 0x0
        # CLOCKS: 0x40008000.
        # SELECTED registers are at 0x08, 0x14, 0x20, 0x2c, 0x38, 0x44, 0x50, 0x5c, 0x68, 0x74.
        # They are used to poll for glitchless mux switch completion (bits show which source is selected).
        Tag <0x40008000 0x8> "ClocksPre" 0x0
        Tag <0x40008008 0x4> "ClkGpout0Selected" 0x1
        Tag <0x4000800c 0x8> "ClocksInter1" 0x0
        Tag <0x40008014 0x4> "ClkGpout1Selected" 0x1
        Tag <0x40008018 0x8> "ClocksInter2" 0x0
        Tag <0x40008020 0x4> "ClkGpout2Selected" 0x1
        Tag <0x40008024 0x8> "ClocksInter3" 0x0
        Tag <0x4000802c 0x4> "ClkGpout3Selected" 0x1
        Tag <0x40008030 0x8> "ClocksInter4" 0x0
        Tag <0x40008038 0x4> "ClkRefSelected" 0x1
        Tag <0x4000803c 0x8> "ClocksInter5" 0x0
        Tag <0x40008044 0x4> "ClkSysSelected" 0x1
        Tag <0x40008048 0x8> "ClocksInter6" 0x0
        Tag <0x40008050 0x4> "ClkPeriSelected" 0x1
        Tag <0x40008054 0x8> "ClocksInter7" 0x0
        Tag <0x4000805c 0x4> "ClkUsbSelected" 0x1
        Tag <0x40008060 0x8> "ClocksInter8" 0x0
        Tag <0x40008068 0x4> "ClkAdcSelected" 0x1
        Tag <0x4000806c 0x8> "ClocksInter9" 0x0
        Tag <0x40008074 0x4> "ClkRtcSelected" 0x1
        Tag <0x40008078 0x3F88> "ClocksRest" 0x0
        # RESETS: 0x4000c000. RESET_DONE is at offset 0x8
        Tag <0x4000c000 0x8> "ResetsPre" 0x0
        Tag <0x4000c008 0x4> "ResetDone" 0x01FFFFFF
        Tag <0x4000c00c 0x3FF4> "ResetsPost" 0x0
        # PSM: 0x40010000. DONE is at offset 0x0c
        Tag <0x40010000 0xc> "PsmPre" 0x0
        Tag <0x4001000c 0x4> "PsmDone" 0x0001FFFF
        Tag <0x40010010 0x3FF0> "PsmRest" 0x0
        Tag <0x40014000 0x4000> "IO_BANK0" 0x0
        Tag <0x40018000 0x4000> "IO_QSPI" 0x0
        Tag <0x4001c000 0x4000> "PADS_BANK0" 0x0
        Tag <0x40020000 0x4000> "PADS_QSPI" 0x0
        # XOSC: 0x40024000. STATUS is at offset 0x4. STABLE is bit 31.
        Tag <0x40024000 0x4> "XOSC_CTRL" 0x0
        Tag <0x40024004 0x4> "XOSC_STATUS" 0x80000000
        Tag <0x40024008 0x3FF8> "XOSC_Rest" 0x0
        # PLL_SYS: 0x40028000. LOCK is bit 31 of CS (offset 0)
        Tag <0x40028000 0x4> "PLL_SYS_CS" 0x80000001
        Tag <0x40028004 0x3FFC> "PLL_SYS_Rest" 0x0
        # PLL_USB: 0x4002c000. LOCK is bit 31 of CS (offset 0)
        Tag <0x4002c000 0x4> "PLL_USB_CS" 0x80000001
        Tag <0x4002c004 0x3FFC> "PLL_USB_Rest" 0x0
        Tag <0x40030000 0x4000> "BusCtrl" 0x0
        Tag <0x40054000 0x4000> "TIMER" 0x0
        Tag <0x40058000 0x4000> "WATCHDOG" 0x0
        Tag <0x40060000 0x4000> "ROSC" 0x0
        # VREG: 0x40064000. ROK is bit 12 (0x1000). Reset value is 0xb1.
        Tag <0x40064000 0x4> "VRegStatus" 0x10b1
        Tag <0x40064004 0x3FFC> "VRegRest" 0x0
        Tag <0x4006c000 0x4000> "TBMAN" 0x5
        Tag <0x50110000 0x4000> "USB" 0x0
